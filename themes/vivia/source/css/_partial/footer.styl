#footer
  background: var(--card-background)
  font-size: 16px
  font-weight: 500
  display: flex
  color: var(--neut-L50)
  margin: 0 auto
  border-radius: card-radius card-radius 0 0
  padding: 0 20px
  align-items: center
  height: 72px
  max-width: 100vw
  overflow: hidden
  box-sizing: border-box
  transition: background trans-style, color trans-style

  a
    @extend $text-link

  #footer-info
    width: 100%
    max-width: 100%
    display: flex
    align-items: center
    justify-content: space-between
    gap: 16px
    min-width: 0
    overflow: hidden
    box-sizing: border-box

  .footer-left
    min-width: 0
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap

  .footer-now-playing
    flex: 0 1 auto
    margin-left: auto
    max-width: 55%
    min-width: 0
    display: block
    text-align: right
    overflow: hidden
    text-overflow: ellipsis
    white-space: nowrap
    box-sizing: border-box

  @media mq-mobile
    #footer-info
      flex-direction: column
      align-items: flex-start
      gap: 4px

    .footer-now-playing
      width: 100%
      max-width: 100%
      min-width: 0
      margin-left: 0
      text-align: left