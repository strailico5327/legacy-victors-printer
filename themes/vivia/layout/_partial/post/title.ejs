<%
  let postTitle = post.title;
  if (!postTitle) {
    postTitle = __('untitled');
  }

  const postLink = post.link || '';
  const isExternalPostLink = /^(https?:)?\/\//i.test(postLink);
%>

<div class="main-title-bar">
  <div class="main-title-dot"></div>
  <% if (post.link){ %>
    <h1 itemprop="name">
      <a class="<%= class_name %>" href="<%- url_for(postLink) %>" <% if (isExternalPostLink) { %>target="_blank" rel="noopener"<% } %> itemprop="url"><%= postTitle %></a>
  <% } else { %>
    <% if (index){ %>
      <h1 itemprop="name">
        <a class="<%= class_name %>" href="<%- url_for(post.path) %>"><%= postTitle %></a>
      </h1>
    <% } else { %>
      <h1 class="<%= class_name %>" itemprop="headline name">
        <%= postTitle %>
      </h1>
    <% } %>
  <% } %>
</div>
