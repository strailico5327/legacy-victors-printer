<footer id="footer">
  <% if (theme.sidebar === 'bottom'){ %>
    <%- partial('_partial/sidebar') %>
  <% } %>
  <div id="footer-info" class="inner">
    <div class="footer-left">
      <% if (theme.copyright){ %>
        <%- render(theme.copyright, 'pug'); %>
      <% } %>
      <span class="footer-copyright">&copy; <%= date(new Date(), 'YYYY') %> <%= theme.author || config.author || config.title %></span>
    </div>

    <a id="lastfm-now-playing" class="footer-now-playing" href="#" target="_blank" rel="noopener noreferrer" aria-live="polite" hidden></a>
  </div>
</footer>

<script src="<%- url_for('/vendor/fancybox/fancybox.umd.js') %>"></script>

<script>
  if (window.Fancybox) {
    Fancybox.bind("[data-fancybox]", {});
  }
</script>

<script>
  (function () {
    const LASTFM_USER = 'strailynx';
    const LASTFM_API_KEY = '9af6648c56167d7cd9bafb34466a6dd3';
    const target = document.getElementById('lastfm-now-playing');

    if (!target || !LASTFM_USER || !LASTFM_API_KEY) return;

    function splitTextForEllipsis(text) {
      const wordUnits = text.match(/\S+\s*/g);

      if (wordUnits && wordUnits.length > 1) {
        return wordUnits;
      }

      return Array.from(text);
    }

    function fitNowPlayingText() {
      if (target.hidden) return;

      const fullText = target.dataset.fullText || target.textContent.trim();

      if (!fullText) return;

      target.textContent = fullText;

      const availableWidth = target.clientWidth;

      if (!availableWidth) return;

      if (target.scrollWidth <= availableWidth) {
        return;
      }

      const units = splitTextForEllipsis(fullText);
      const fallback = fullText.startsWith('♪') ? '♪ …' : '…';

      let left = 0;
      let right = units.length;
      let best = fallback;

      while (left <= right) {
        const mid = Math.floor((left + right) / 2);
        const candidate = units.slice(0, mid).join('').trimEnd() + '…';

        target.textContent = candidate;

        if (target.scrollWidth <= availableWidth) {
          best = candidate;
          left = mid + 1;
        } else {
          right = mid - 1;
        }
      }

      target.textContent = best;
    }

    let fitFrame = null;

    function scheduleFitNowPlayingText() {
      if (fitFrame) {
        cancelAnimationFrame(fitFrame);
      }

      fitFrame = requestAnimationFrame(function () {
        fitFrame = null;
        fitNowPlayingText();
      });
    }

    async function updateLastfmNowPlaying() {
      const params = new URLSearchParams({
        method: 'user.getrecenttracks',
        user: LASTFM_USER,
        api_key: LASTFM_API_KEY,
        format: 'json',
        limit: '1'
      });

      try {
        const response = await fetch(`https://ws.audioscrobbler.com/2.0/?${params.toString()}`, {
          cache: 'no-store'
        });

        if (!response.ok) throw new Error(`Last.fm HTTP ${response.status}`);

        const data = await response.json();
        const track = data?.recenttracks?.track?.[0];

        if (!track) {
          target.hidden = true;
          return;
        }

        const title = track.name || '';
        const artist = track.artist?.['#text'] || track.artist?.name || '';
        const isNowPlaying = track['@attr']?.nowplaying === 'true';

        if (!title || !artist || !isNowPlaying) {
          target.hidden = true;
          return;
        }

        const fullText = `♪ ${title} - ${artist}`;

        target.dataset.fullText = fullText;
        target.textContent = fullText;
        target.title = fullText;
        target.hidden = false;

        if (track.url) {
          target.href = track.url;
        } else {
          target.removeAttribute('href');
        }

        scheduleFitNowPlayingText();
      } catch (error) {
        console.warn('Last.fm footer failed:', error);
        target.hidden = true;
      }
    }

    window.addEventListener('resize', scheduleFitNowPlayingText);

    if ('ResizeObserver' in window) {
      const resizeObserver = new ResizeObserver(scheduleFitNowPlayingText);
      resizeObserver.observe(target.parentElement || target);
    }

    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(scheduleFitNowPlayingText);
    }

    updateLastfmNowPlaying();
    setInterval(updateLastfmNowPlaying, 60000);
  })();
</script>